<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <!-- Pre-10 only: writing recordings to public Downloads. 10+ uses MediaStore (no permission). -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="Rook"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Rook">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Rook">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".location.MovementService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <service
            android:name=".location.RecordingService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <service
            android:name=".RookPresenceService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>
